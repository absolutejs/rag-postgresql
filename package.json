{
  "name": "@absolutejs/absolute-rag-postgresql",
  "version": "0.0.5",
  "description": "PostgreSQL adapter package for AbsoluteJS RAG workflows, with pgvector as the first vector implementation",
  "license": "BSL-1.1",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "sideEffects": false,
  "files": [
    "README.md",
    "index.js",
    "index.d.ts",
    "NEXT_STEPS.md"
  ],
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "scripts": {
    "check": "node ./scripts/check-scaffold.mjs",
    "test": "bun test",
    "smoke:docker": "bun run ./scripts/smoke-docker.mjs",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release:package": "bun publish --access public"
  },
  "peerDependencies": {
    "@absolutejs/rag": ">=0.0.3 <0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/absolutejs/rag-postgresql.git"
  },
  "keywords": [
    "absolutejs",
    "rag",
    "postgresql",
    "pgvector",
    "vector"
  ],
  "dependencies": {
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@absolutejs/rag": "0.0.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.5.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
